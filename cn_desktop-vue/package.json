{
  "name": "cn-desktop-vue",
  "version": "1.0.3",
  "description": "Clone-NPM 桌面应用 - Vue 3 + Electron",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "bump": "node bump-version.js",
    "package": "node bump-version.js && electron-vite build && electron-builder --win --config",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "element-plus": "^2.6.1",
    "marked": "^18.0.2",
    "node-pty": "^1.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.1.0",
    "sass": "^1.71.1",
    "vite": "^5.1.6"
  },
  "build": {
    "appId": "com.wmj.cn-desktop-vue",
    "productName": "Clone-NPM Desktop Vue",
    "artifactName": "Clone-NPM Desktop Vue Setup ${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "config.json",
        "to": "config.json"
      },
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
